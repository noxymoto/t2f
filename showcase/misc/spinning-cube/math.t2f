// fp_sin(deg) -> sin(deg) * 1000, handles all 360 degrees
fn fp_sin(deg) {
    // Normalize to 0..359
    let d = deg;
    while (d < 0) {
        d = d + 360;
    }
    while (d > 359) {
        d = d - 360;
    }
    if (d < 90) {
        return mem_get(_sin_table, d);
    }
    if (d < 180) {
        return mem_get(_sin_table, 180 - d);
    }
    if (d < 270) {
        return 0 - mem_get(_sin_table, d - 180);
    }
    return 0 - mem_get(_sin_table, 360 - d);
}

// fp_cos(deg) -> cos(deg) * 1000
fn fp_cos(deg) {
    return fp_sin(deg + 90);
}

// fp_mul(a, b) -> (a * b) / 1000  (fixed point multiply)
fn fp_mul(a, b) {
    return (a * b) / 1000;
}

// fp_abs(a) -> absolute value
fn fp_abs(a) {
    if (a < 0) {
        return 0 - a;
    }
    return a;
}
