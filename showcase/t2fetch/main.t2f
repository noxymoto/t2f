    if (line == 8) { tty_print(":MMM\x1b[0m\x1b[37m:MMMM\x60  :MM.  -MM-  .MM:  \x60MMMM-\x1b[0m\x1b[38;5;202mMMM:\x1b[0m    "); }
    if (line == 9) { tty_print(":MMM\x1b[0m\x1b[37m:MMMM\x60  :MM.  -MM-  .MM:  \x60MMMM:\x1b[0m\x1b[38;5;202mMMM:\x1b[0m    "); }
    if (line == 10) { tty_print(":MMM\x1b[0m\x1b[37m:MMMM\x60  :MM.  -MM-  .MM:  \x60MMMM-\x1b[0m\x1b[38;5;202mMMM:\x1b[0m    "); }
    if (line == 11) { tty_print(".MMM\x1b[0m\x1b[37m.MMMM\x60  :MM:--:MM:--:MM:  \x60MMMM.\x1b[0m\x1b[38;5;202mMMM.\x1b[0m    "); }
    if (line == 12) { tty_print(" :MMM\x1b[0m\x1b[37m:MMM-  \x60-MMMMMMMMMMMM-\x60  -MMM-\x1b[0m\x1b[38;5;202mMMM:\x1b[0m     "); }
    if (line == 13) { tty_print("  :MMM\x1b[0m\x1b[37m:MMM:\x60                \x60:MMM:\x1b[0m\x1b[38;5;202mMMM:\x1b[0m      "); }
    if (line == 14) { tty_print("   .MMM\x1b[0m\x1b[37m.MMMM:--------------:MMMM.\x1b[0m\x1b[38;5;202mMMM.\x1b[0m       "); }
