fn print_penguin_art_arch(line) {
    tty_bold();
    if (line == 0) { tty_print("                  -\x60\x1b[0m                     "); }
    if (line == 1) { tty_print("                 .o+\x60\x1b[0m                    "); }
    if (line == 2) { tty_print("                \x60ooo/\x1b[0m                    "); }
    if (line == 3) { tty_print("               \x60+oooo:\x1b[0m                   "); }
    if (line == 4) { tty_print("              \x60+oooooo:\x1b[0m                  "); }
    if (line == 5) { tty_print("              -+oooooo+:\x1b[0m                 "); }
    if (line == 6) { tty_print("            \x60/:-:++oooo+:\x1b[0m                "); }
    if (line == 7) { tty_print("           \x60/++++/+++++++:\x1b[0m               "); }
    if (line == 8) { tty_print("          \x60/++++++++++++++:\x1b[0m              "); }
    if (line == 9) { tty_print("         \x60/+++o\x1b[0m\x1b[38;5;202moooooooo\x1b[0m\x1b[37moooo/\x60\x1b[0m            "); }
    if (line == 10) { tty_print("        ./\x1b[0m\x1b[38;5;202mooosssso++osssssso\x1b[0m\x1b[37m+\x60\x1b[0m           "); }
    if (line == 11) { tty_print("\x1b[0m\x1b[38;5;202m       .oossssso-\x60\x60\x60\x60/ossssss+\x60\x1b[0m          "); }
    if (line == 12) { tty_print("      -osssssso.      :ssssssso.\x1b[0m         "); }
    if (line == 13) { tty_print("     :osssssss/        osssso+++.\x1b[0m        "); }
    if (line == 14) { tty_print("    /ossssssss/        +ssssooo/-\x1b[0m        "); }
    if (line == 15) { tty_print("  \x60/ossssso+/:-        -:/+osssso+-\x1b[0m      "); }
    if (line == 16) { tty_print(" \x60+sso+:-\x60                 \x60.-/+oso:\x1b[0m     "); }
    if (line == 17) { tty_print("\x60++:.                           \x60-/+/\x1b[0m    "); }
    if (line == 18) { tty_print(".\x60                                 \x60/\x1b[0m    "); }
    tty_reset();
    return 19;
}

fn print_penguin_art_kali(line) {
    tty_bold();
    if (line == 0) { tty_print("..............\x1b[0m                                      "); }
    if (line == 1) { tty_print("            ..,;:ccc,.\x1b[0m                              "); }
    if (line == 2) { tty_print("          ......\x27\x27\x27;lxO.\x1b[0m                            "); }
    if (line == 3) { tty_print(".....\x27\x27\x27\x27..........,:ld;\x1b[0m                            "); }
    if (line == 4) { tty_print("           .\x27;;;:::;,,.x,\x1b[0m                           "); }
    if (line == 5) { tty_print("      ..\x27\x27\x27.            0Xxoc:,.  ...\x1b[0m               "); }
    if (line == 6) { tty_print("  ....                ,ONkc;,;cokOdc\x27,.\x1b[0m             "); }
    if (line == 7) { tty_print(" .                   OMo           \x27:\x1b[0m\x1b[38;5;202mdd\x1b[0m\x1b[37mo.\x1b[0m           "); }
    if (line == 8) { tty_print("                    dMc               :OO;\x1b[0m          "); }
    if (line == 9) { tty_print("                    0M.                 .:o.\x1b[0m        "); }
    if (line == 10) { tty_print("                    ;Wd\x1b[0m                             "); }
    if (line == 11) { tty_print("                     ;XO,\x1b[0m                           "); }
    if (line == 12) { tty_print("                       ,d0Odlc;,..\x1b[0m                  "); }
    if (line == 13) { tty_print("                           ..\x27,;:cdOOd::,.\x1b[0m          "); }
    if (line == 14) { tty_print("                                    .:d;.\x27:;.\x1b[0m       "); }
    if (line == 15) { tty_print("                                       \x27d,  .\x27\x1b[0m      "); }
    if (line == 16) { tty_print("                                         ;l   ..\x1b[0m    "); }
    if (line == 17) { tty_print("                                          .o\x1b[0m        "); }
    if (line == 18) { tty_print("                                            c\x1b[0m       "); }
    if (line == 19) { tty_print("                                            .\x27\x1b[0m      "); }
    if (line == 20) { tty_print("                                             .\x1b[0m      "); }
    tty_reset();
    return 21;
}
fn print_logo_line(line, os_buf) {
    // We check the first few characters of the OS buffer
    // U = 85 (Ubuntu), D = 68 (Debian), A = 65 (Arch)
    
    let first_char = get_byte(os_buf, 0);

    if (first_char == 85) { // 'U' for Ubuntu
        print_penguin_art_ubuntu(line);
    } 
 if (first_char == 68) { // 'D' for Debian
        print_penguin_art_debian(line);
    }
     if (first_char == 70) { // 'F' for Fedora
        print_penguin_art_fedora(line);
    }

      if (first_char == 76) { // 'L' for linux mint
        print_penguin_art_mint(line);
    }

     if (first_char == 65) { // 'A' for Arch
        print_penguin_art_arch(line);
    } 

     if (first_char == 75) { // 'K' for kali
        print_penguin_art_kali(line);
    } 
}

fn print_info_line(line) {
    if (line == 0) {
     
        print_header_line();
    }
    if (line == 1) {
   
        print_rule();
    }
    if (line == 2) {
  
        print_key_value("os", os_buf);
    }
    if (line == 3) {
    
        print_key_value("environment", env_buf);
    }
    if (line == 4) {
        print_key_value("kernel", kernel_buf);
    }
    if (line == 5) {
        print_key_value("uptime", uptime_buf);
    }
    if (line == 6) {
        print_key_value("cpu", cpu_buf);
    }
    if (line == 7) {
        print_key_value("shell", shell_buf);
    }
    if (line == 8) {
        print_memory_line();
    }
    if (line == 9) {
      
        print_disk_line();
    }
    if (line == 10) {
        print_battery_line();
  
    }

    if (line == 11) {

        print_str("");
    }


    if (line == 12) {
        print_color_swatches_light(4);
      

          
    }


}


tty_clear();
tty_print("");
tty_nl();

extract_username(user_buf);
if (buf_is_empty(user_buf)) {
    copy_cstr("user", user_buf);
}

extract_hostname(host_name_buf);
if (buf_is_empty(host_name_buf)) {
    copy_cstr("computer", host_name_buf);
}

copy_cstr(user_buf, host_buf);
let host_at = str_len(host_buf);
set_byte(host_buf, host_at, 64);
set_byte(host_buf, host_at + 1, 0);
append_text(host_buf, host_at + 1, host_name_buf);

extract_os_pretty_name(os_buf);
extract_os_id(os_id_buf);
extract_kernel(kernel_buf);
extract_cpu_model(cpu_buf);
extract_shell_name(shell_buf);
extract_mem_total(mem_total_buf);
extract_mem_available(mem_avail_buf);
extract_battery_capacity(battery_cap_buf);
extract_battery_status(battery_status_buf);

build_uptime_text(extract_uptime_minutes(), uptime_buf);
if (is_wsl_kernel()) {
    copy_cstr("Windows Subsystem for Linux", env_buf);
} else {
    copy_cstr("Linux", env_buf);
}

let line = 0;
let first_char = get_byte(os_buf, 0);
let a = 30;

    if (first_char == 85) { // 'U' for Ubuntu
       a = 21;

       //a = 21;
    } 
 if (first_char == 68) { // 'D' for Debian
        a = 17;
    }
     if (first_char == 70) { // 'F' for Fedora
        a = 20;
    }

       if (first_char == 76) { // 'L' for linux mint
        a = 19;
    }
        if (first_char == 65) { // 'A' for arch linux
        a = 19;
    }
           if (first_char == 75) { // 'K' for kali
        a = 22;
    }
while (line < a) {
    print_logo_line(line);
    print_gap();
    print_info_line(line);
    if (line > 11) {
        tty_nl();
    }
    line = line + 1;
}
