    if (line == 3) { tty_print("        \x1b[38;5;202m.;looooool:,\x27\x27.  \x1b[37m:ooooooooooc         "); }
    if (line == 4) { tty_print("       \x1b[38;5;202m;looool;.         \x1b[37m\x27oooooooooo,         "); }
    if (line == 5) { tty_print("      \x1b[38;5;202m;clool\x27             \x1b[37m.cooooooc.  \x1b[38;5;202m,,      "); }
    if (line == 6) { tty_print("         \x1b[38;5;202m...                \x1b[37m......  \x1b[38;5;202m.:oo,     "); }
    if (line == 7) { tty_print("  \x1b[37m.;clol:,.                        \x1b[38;5;202m.loooo\x27    "); }
    if (line == 8) { tty_print(" \x1b[37m:ooooooooo,                        \x1b[38;5;202m\x27ooool    "); }
    if (line == 9) { tty_print("\x1b[37m\x27ooooooooooo.                        \x1b[38;5;202mloooo.   "); }
    if (line == 10) { tty_print("\x1b[37m\x27ooooooooool                         \x1b[38;5;202mcoooo.   "); }
    if (line == 11) { tty_print(" \x1b[37m,loooooooc.                        \x1b[38;5;202m.loooo.   "); }
    if (line == 12) { tty_print("   \x1b[37m.,;;;\x27.                          \x1b[38;5;202m;ooooc    "); }
    if (line == 13) { tty_print("       \x1b[38;5;202m...                         \x1b[38;5;202m,ooool.    "); }
    if (line == 14) { tty_print("    \x1b[38;5;202m.cooooc.              \x1b[37m..\x27,,\x27.  \x1b[38;5;202m.cooo.     "); }
    if (line == 15) { tty_print("      \x1b[38;5;202m;ooooo:.           \x1b[37m;oooooooc.  \x1b[38;5;202m:l.      "); }
    if (line == 16) { tty_print("       \x1b[38;5;202m.coooooc,..      \x1b[37mcoooooooooo.          "); }
    if (line == 17) { tty_print("         \x1b[38;5;202m.:ooooooolc:. \x1b[37m.ooooooooooo\x27          "); }
    if (line == 18) { tty_print("           \x1b[38;5;202m.\x27:loooooo;  \x1b[37m,oooooooooc           "); }
    if (line == 19) { tty_print("               \x1b[38;5;202m..\x27;::c\x27  \x1b[37m.;loooo:\x27            "); }
    tty_reset();
}

